# Spotify API credentials
# Create at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Google OAuth credentials (for YouTube Music)
# Create at https://console.cloud.google.com/apis/credentials
# Must be "TVs and Limited Input devices" OAuth client type
# Enable "YouTube Data API v3" in your project
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Base URL of the app (needed for Spotify redirect)
# Use your ngrok URL or local IP for mobile access
BASE_URL=http://localhost:8000

# Secret key for session signing (generate a random string)
SECRET_KEY=change-me-to-a-random-string
